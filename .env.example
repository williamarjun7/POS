# ═══════════════════════════════════════════════════════════
# InsForge Backend
# ═══════════════════════════════════════════════════════════
VITE_INSFORGE_URL=https://your-app.region.insforge.app
VITE_INSFORGE_ANON_KEY=your-anon-key-here
# Override auto-derived function URL (run `insforge functions list` to find yours)
VITE_INSFORGE_FUNCTIONS_URL=

# ═══════════════════════════════════════════════════════════
# Fonepay Dynamic QR Payment (production)
# ═══════════════════════════════════════════════════════════
# Merchant code assigned by Fonepay
VITE_FONEPAY_MERCHANT_CODE=
# Fonepay API base URL (production: https://merchantapi.fonepay.com/api)
VITE_FONEPAY_API_BASE_URL=https://merchantapi.fonepay.com/api

# ═══════════════════════════════════════════════════════════
# InsForge Edge Function Secrets (set via `insforge secrets set`)
# These are NOT VITE_ variables — they are server-side only.
# ═══════════════════════════════════════════════════════════
# Run these commands to configure:
#   insforge secrets set FONEPAY_MERCHANT_CODE=<merchant_code>
#   insforge secrets set FONEPAY_USERNAME=<fonepay_username>
#   insforge secrets set FONEPAY_PASSWORD=<fonepay_password>
#   insforge secrets set FONEPAY_SECRET_KEY=<hmac_secret_key>
#   insforge secrets set FONEPAY_API_BASE_URL=https://merchantapi.fonepay.com/api
