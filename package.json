{
  "name": "pos-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:analyze": "ANALYZE_BUNDLE=true vite build",
    "preview": "vite preview",
    "lint": "oxlint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:perf": "vitest bench",
    "lighthouse": "lighthouse http://localhost:5173 --view --output-path=./lighthouse-reports/report.html",
    "lighthouse:ci": "lhci autorun",
    "k6:login": "k6 run tests/k6/login.js",
    "k6:menu": "k6 run tests/k6/menu-load.js",
    "k6:orders": "k6 run tests/k6/order-creation.js",
    "k6:payments": "k6 run tests/k6/payment-processing.js",
    "k6:dashboard": "k6 run tests/k6/dashboard-load.js",
    "k6:booking": "k6 run tests/k6/rooms-booking.js",
    "k6:mixed": "k6 run tests/k6/mixed-workload.js",
    "k6:stress": "k6 run --stage 1m:50,1m:100,1m:200,1m:300,1m:500,1m:1000,2m:1000,1m:0 tests/k6/mixed-workload.js",
    "k6:endurance": "k6 run --stage 5m:20,8h:20,5m:0 tests/k6/mixed-workload.js",
    "db:profile": "psql \"$DATABASE_URL\" -f tests/db/performance-profiling.sql",
    "db:seed": "psql \"$DATABASE_URL\" -f tests/db/seed-large-dataset.sql",
    "perf:all": "npm run build:analyze && npm run test:perf"
  },
  "dependencies": {
    "@insforge/sdk": "^1.4.4",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@supabase/supabase-js": "^2.110.2",
    "@tanstack/react-query": "^5.101.2",
    "boneyard-js": "^1.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.24.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.21",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "postcss": "^8.5.4",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}
