{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "insforge": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@insforge/mcp@latest"
      ],
      "environment": {
        "API_KEY": "${INSFORGE_API_KEY}",
        "API_BASE_URL": "${INSFORGE_API_BASE_URL}"
      }
    }
  }
}
